# ─────────────────────────────────────────────────────────────────────────────
# KTP System — Environment Variables
# Salin file ini menjadi .env dan isi semua nilai sebelum menjalankan Docker
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password (buat password yang kuat)
DB_PASSWORD=ganti_dengan_password_kuat

# Session secret untuk Express (minimal 32 karakter acak)
# Generate: openssl rand -base64 32
SESSION_SECRET=ganti_dengan_secret_panjang_dan_acak

# Groq API Key (untuk OCR berbasis AI)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot Token (bot registrasi KTP)
# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Report Bot Token (bot laporan harian)
TELEGRAM_REPORT_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID grup/channel Telegram untuk laporan harian
# Jalankan bot di grup, lalu cek dengan: https://api.telegram.org/bot<TOKEN>/getUpdates
REPORT_CHAT_ID=-1001234567890
